# Vercel AI Gateway — used by the AI SDK via "provider/model" strings.
# Create a key in the Vercel dashboard (AI Gateway) and set it here.
AI_GATEWAY_API_KEY=

# Default model used by all ministry-planning agents.
MINISTRY_MODEL=anthropic/claude-sonnet-4-6

# Optional stronger model for the Pastoral Theology specialist (Scripture/gospel
# foundation + theology review). Opus is recommended. Falls back to MINISTRY_MODEL.
MINISTRY_THEOLOGY_MODEL=anthropic/claude-opus-4-8

# When unset, agents run in deterministic "offline draft" mode (no API calls).
# Set to "1" to force offline mode even when a gateway key is present.
MINISTRY_OFFLINE=

# --- Roadmap persistence (the /roadmap planning board) ---
# A Vercel-Marketplace KV / Upstash Redis store holds the single shared roadmap
# ("roadmap:default"). Add the Upstash Redis integration on Vercel and these are
# set for you. When unset, /roadmap falls back to in-memory (per-process) so
# local dev needs zero setup — but production needs KV for cross-device sharing.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are also accepted.)
